<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="GlyphToneGitHub" value="https://nuget.pkg.github.com/jrolofsson/index.json" />
  </packageSources>
  <packageSourceCredentials>
    <GlyphToneGitHub>
      <add key="Username" value="%GLYPHTOON_GITHUB_USERNAME%" />
      <add key="ClearTextPassword" value="%GLYPHTOON_GITHUB_PAT%" />
    </GlyphToneGitHub>
  </packageSourceCredentials>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="Microsoft.*" />
      <package pattern="coverlet.collector" />
      <package pattern="xunit" />
      <package pattern="xunit.*" />
    </packageSource>
    <packageSource key="GlyphToneGitHub">
      <package pattern="GlyphTone.Encoder" />
    </packageSource>
  </packageSourceMapping>
</configuration>
